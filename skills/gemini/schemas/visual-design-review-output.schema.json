{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "visual-design-review-output",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "findings"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["ship", "ship-with-followups", "redesign-recommended"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "designMd": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "present": { "type": "boolean" },
        "path": { "type": "string" },
        "lintErrors": { "type": "array", "items": { "type": "string" } },
        "lintWarnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["axis", "severity", "title", "where", "problem", "impact", "fix"],
        "properties": {
          "axis": {
            "type": "string",
            "enum": [
              "brand-fidelity",
              "color",
              "typography",
              "spacing",
              "layout",
              "components",
              "elevation",
              "shapes",
              "accessibility",
              "consistency",
              "dos-and-donts"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "title": { "type": "string", "minLength": 1 },
          "where": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "screenshot": { "type": "string" },
              "file": { "type": "string" },
              "element": { "type": "string" }
            }
          },
          "tokenRef": {
            "type": "string",
            "description": "Dotted DESIGN.md token path, e.g. 'colors.primary' or 'spacing.md'"
          },
          "problem": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 },
          "fix": { "type": "string", "minLength": 1 },
          "wcag": {
            "type": "object",
            "additionalProperties": false,
            "required": ["foreground", "background", "ratio", "required"],
            "properties": {
              "foreground": { "type": "string" },
              "background": { "type": "string" },
              "ratio": { "type": "number", "minimum": 1 },
              "required": { "type": "number", "minimum": 1 }
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "whats_working": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "open_questions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
